{
  "auth": {
    "providers": {
      "googleSignIn": {
        "enabled": true,
        "oAuthBrandDisplayName": "StoryBox 知識盒子",
        "supportEmail": "xapableteam@gmail.com",
        "authorizedRedirectUris": ["https://storybox-af3b7.web.app", "https://storybox.work", "http://localhost"]
      }
    }
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions"
  }
}
